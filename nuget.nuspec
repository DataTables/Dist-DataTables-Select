<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <version>4.0.0-beta.1</version>
        <id>datatables.net-select</id>
        <description>This is Select for DataTables</description>
        <repository type="git" url="https://github.com/DataTables/Select"/>
        <authors>SpryMedia Ltd</authors>
        <projectUrl>http://datatables.net</projectUrl>
        <license type="expression">MIT</license>
        <tags>select  selection  Datatables table</tags>
        <dependencies>
            <dependency id="datatables.net" version="3.0.0-0"/>
        </dependencies>
        <contentFiles>
            <files include="**/*" buildAction="Content"/>
        </contentFiles>
        <readme>Readme.md</readme>
    </metadata>
    <files>
        <file src="Readme.md" target=""/>
        <file src="js/dataTables.select.js" target="content\Scripts"/>
        <file src="js/dataTables.select.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/dataTables.select.min.js" target="content\Scripts"/>
        <file src="js/dataTables.select.min.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/dataTables.select.min.mjs" target="content\Scripts"/>
        <file src="js/dataTables.select.min.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/dataTables.select.mjs" target="content\Scripts"/>
        <file src="js/dataTables.select.mjs" target="contentFiles\any\any\wwwroot\js"/>
    </files>
</package>
